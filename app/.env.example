APP_ENV=development
MODE=development
PORT=5000
HOST=127.0.0.1
NUXT_PUBLIC_BASE_URL=http://127.0.0.1:5000
NUXT_PUBLIC_API_URL="http://127.0.0.1:3000/api/v1"
