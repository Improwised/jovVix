    "@vueuse/core": "^14.3.0",
    "chart.js": "^4.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-vue": "^8.6.0",
    "highlight.js": "^11.10.0",
    "lucide-vue-next": "^1.0.0",
